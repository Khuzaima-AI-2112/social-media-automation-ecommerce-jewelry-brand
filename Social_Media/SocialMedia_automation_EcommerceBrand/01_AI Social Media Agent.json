          "id": "8koivhc5Ax5axXSi",
          "name": "OpenAi account"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Parse XML RSS feed data and structure products\nconst data = $json;\nconst products = [];\n\n// Navigate through the XML structure to find products\nif (data.rss && data.rss.channel && data.rss.channel.item) {\n  const xmlProducts = Array.isArray(data.rss.channel.item) \n    ? data.rss.channel.item \n    : [data.rss.channel.item];\n  \n  xmlProducts.forEach(product => {\n    products.push({\n      ProductID: product['g:id'] || Math.random().toString(36).substr(2, 9),\n      Name: product['g:title'],\n      Price: product['g:price'] || 'Contact for price',\n      Description: product['g:description'],\n      ImageURL: product['g:image_link'],\n      AdditionalImageURL: product['g:additional_image_link'],\n      ProductPageURL: product['g:link'],\n      Availability: product['g:availability'],\n      Category: 'Jewelry',\n      Status: 'pending',\n      LastUpdated: new Date().toISOString()\n    });\n  });\n}\n\n// Return all products as a single consolidated object\nreturn {\n  json: {\n    products: products,\n    totalCount: products.length,\n    processedAt: new Date().toISOString()\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        96,
        64
      ],
      "id": "3290afe1-67f0-4182-bd73-c036dd727dde",
      "name": "Parse XML RSS feed data and structure products"
    },
    {
      "parameters": {
        "jsCode": "// Prepare individual products for Google Sheets\nconst data = $json;\nconst results = [];\n\n// Extract each product from the products array\nif (data.products && Array.isArray(data.products)) {\n  data.products.forEach(product => {\n    results.push({\n      ProductID: product.ProductID,\n      Name: product.Name,\n      Price: product.Price,\n      Description: product.Description,\n      ImageURL: product.ImageURL,\n      ProductPageURL: product.ProductPageURL,\n      Availability: product.Availability,\n      Status: product.Status,\n      PostDate: '', // Empty initially\n      LastUpdated: product.LastUpdated\n    });\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        96,
        224
      ],
      "id": "d3d09da4-69ac-4567-8d27-a158c9e4dff5",
      "name": "Prepare individual products for Google Sheets"
    },
    {
      "parameters": {
        "jsCode": "// Input: Array of sheet rows from Google Sheets\nconst rows = $input.all();  // Get all input items (rows)\nconst pendingProducts = [];\n\n// Filter for pending products\nrows.forEach(row => {\n  const product = row.json;  // Each row is a JSON object\n  if (product.Status === 'pending') {\n    pendingProducts.push(product);\n  }\n});\n\nlet selectedProduct = null;\n\nif (pendingProducts.length > 0) {\n  // Select a random index\n  const randomIndex = Math.floor(Math.random() * pendingProducts.length);\n  selectedProduct = pendingProducts[randomIndex];\n  // Optionally, add a timestamp for when it was selected\n  selectedProduct.SelectionTimestamp = new Date().toISOString();\n  console.log(`Selected random pending product: ${selectedProduct.Name}`);\n} else {\n  // Fallback: Select random from all products, or handle no products\n  if (rows.length > 0) {\n    const randomIndex = Math.floor(Math.random() * rows.length);\n    selectedProduct = rows[randomIndex].json;\n    selectedProduct.SelectionTimestamp = new Date().toISOString();\n    selectedProduct.IsFallback = true;  // Flag it as fallback\n    console.log(`No pending products; selected random from all: ${selectedProduct.Name}`);\n  } else {\n    // No products at all\n    return [{ json: { error: 'No products found in sheet' } }];\n  }\n}\n\n// Output the single selected product\nreturn [{ json: selectedProduct }];"
      },
