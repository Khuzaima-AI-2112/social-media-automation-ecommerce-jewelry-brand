    {
      "parameters": {
        "jsCode": "// Check for errors in media container creation\nconst input = $input.first();\n\nif (input?.json?.error) {\n  console.log('Instagram media container error:', input.json.error);\n  \n  return [{\n    json: {\n      error: 'instagram_container_failed',\n      message: input.json.error.message,\n      productId: $('Selecting random products').item.json.ProductID,\n      skipInstagram: true\n    }\n  }];\n}\n\n// If no error, pass through the data\nreturn [input];"
      },
