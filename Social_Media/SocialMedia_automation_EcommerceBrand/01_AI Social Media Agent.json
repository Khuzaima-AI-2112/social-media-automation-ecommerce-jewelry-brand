    {
      "parameters": {
        "jsCode": "const input = $input.first();\nconst facebookData = input.json[0] || {}; // First item from Facebook branch\nconst instagramData = input.json[1] || {}; // Second item from Instagram branch\nconst productNode = $('Selecting random products');\nconst productData = (productNode && productNode.all().length && productNode.first().json) ? productNode.first() : { json: {} };\n\nconst result = {\n  ProductID: productData.json.ProductID || '',\n  Status: 'posted',\n  PostDate: new Date().toISOString(),\n  FacebookPostID: facebookData.id || 'failed',\n  InstagramPostID: instagramData.id || (instagramData.skipInstagram ? 'skipped_due_to_limit' : 'failed'),\n  PostingStatus: 'both_attempted'\n};\n\nif (facebookData.id && instagramData.id) {\n  result.PostingStatus = 'both_successful';\n} else if (facebookData.id) {\n  result.PostingStatus = 'facebook_only';\n} else if (instagramData.id) {\n  result.PostingStatus = 'instagram_only';\n} else {\n  result.PostingStatus = 'both_failed';\n}\n\nif (instagramData.skipInstagram) {\n  result.PostingStatus = 'facebook_only';\n  result.InstagramPostID = 'skipped_due_to_limit';\n}\n\nreturn [{ json: result }];"
