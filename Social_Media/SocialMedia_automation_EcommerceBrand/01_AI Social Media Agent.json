    {
      "parameters": {
        "jsCode": "const inputData = $input.first();\nconsole.log('Input Data Received:', JSON.stringify(inputData, null, 2));\nconst sheetData = $(\"Get row(s) in sheet\").items;\nconsole.log('Sheet Data Received:', JSON.stringify(sheetData, null, 2));\nconst today = new Date().toDateString();\nlet todaysPosts = 0;\nif (sheetData && sheetData.length > 0) {\n  sheetData.forEach(row => {\n    if (row.json && row.json.PostDate && row.json.InstagramPostID && row.json.InstagramPostID !== 'failed') {\n      try {\n        const postDate = new Date(row.json.PostDate).toDateString();\n        console.log(`Checking row PostDate: ${postDate}, InstagramPostID: ${row.json.InstagramPostID}`);\n        if (postDate === today) {\n          todaysPosts++;\n          console.log(`Incremented todaysPosts to ${todaysPosts}`);\n        }\n      } catch (e) {\n        console.log(`Error parsing PostDate for row: ${JSON.stringify(row)}, Error: ${e.message}`);\n      }\n    }\n  });\n} else {\n  console.log('No sheet data available or invalid sheet data');\n}\nconsole.log(`Instagram posts today: ${todaysPosts}`);\nconst result = {\n  ...inputData.json,\n  todaysPosts: todaysPosts,\n  skipInstagram: todaysPosts >= 20,\n  reason: todaysPosts >= 20 ? 'Daily Instagram limit reached' : undefined,\n  InstagramPostID: todaysPosts >= 20 ? 'skipped_due_to_limit' : undefined\n};\nif (result.skipInstagram) {\n  console.log('Daily limit reached, skipping Instagram');\n} else {\n  console.log('Proceeding with Instagram posting');\n}\nreturn [{ json: result }];"
      },
